kafkaWorker: #Node & {
    name: "payment-worker"
    kind: "worker"

    ports: [
        {
            name:       "kafka-payments"
            direction:  "in"
            protocol:   "kafka"
            messageType: "PaymentRequestedEvent"
            config: {
                topic:  "payments.requested"
                groupId: "payment-worker"
            }
        },
    ]

    domainHandlers: [
        {
            name:       "ProcessPayment"
            inputType:  "PaymentRequestedEvent"
            outputType: "PaymentProcessedEvent"
            impl: {
                language: "go"
                ref:      "github.com/acme/payments.ProcessPayment"
            }
        },
    ]

    adapters: [] // можно добавить, если нужен маппинг форматов
}
