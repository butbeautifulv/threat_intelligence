# Full enrich: seed Neo4j from BASE pack, ~10 NVD pages, respect crawl ledger (var/veil).
GRAPH_PACK_SKIP=0
GRAPH_PACK_DEFAULT=1
BASE_GRAPH_PACK_VERSION=${BASE_GRAPH_PACK_VERSION:-v0.4.1}
GRAPH_PACK_DEFAULT_VERSION=${BASE_GRAPH_PACK_VERSION}
SCRAPE_FORCE_REFETCH=0
SCRAPE_SOURCES=ds,vuln,lola,ti,sbom,coderules,nuclei

NVD_MAX_PAGES=10
NVD_RESULTS_PER_PAGE=500
VULN_METASPLOIT_MAX_RB=0
VULN_EXPLOITDB_MAX_ROWS=5000

DS_MAX_ATOMIC=0
DS_MAX_SIGMA=120
DS_MAX_YARA=80
DS_MAX_CALDERA=40

SBOM_SOURCES=osv,ghsa
SBOM_MAX_CVES=80
SBOM_MAX_GHSA=50

CODERULES_MAX_SEMGREP=40
CODERULES_MAX_CODEQL=30
NUCLEI_MAX=60
NUCLEI_YEARS=2023,2024,2025,2026

LOLA_MITRE_MAX_TECHNIQUES=2000
LOFTS_SKIP_ON_ERROR=true
