# Fast-rich graph pack profile (~25 min). Source: deploy/profiles/fast-rich.env
GRAPH_PACK_SKIP=1
SCRAPE_FORCE_REFETCH=1
SCRAPE_SOURCES=ds,vuln,lola,ti,sbom,coderules,nuclei

NVD_MAX_PAGES=1
VULN_METASPLOIT_MAX_RB=0
VULN_EXPLOITDB_MAX_ROWS=5000

DS_MAX_ATOMIC=0
DS_MAX_SIGMA=120
DS_MAX_YARA=80
DS_MAX_CALDERA=40

SBOM_SOURCES=osv,ghsa
SBOM_MAX_CVES=80
SBOM_MAX_GHSA=50

CODERULES_MAX_SEMGREP=40
CODERULES_MAX_CODEQL=30
NUCLEI_MAX=60

LOLA_MITRE_MAX_TECHNIQUES=2000
LOFTS_SKIP_ON_ERROR=true
