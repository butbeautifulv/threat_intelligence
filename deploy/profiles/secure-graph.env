# Secure graph read-path profile (use with compose.secure.yml).
# Do not commit production secrets; inject via secret manager / env files excluded from git.

AUTH_ENABLED=1
RBAC_ENABLED=1
VEIL_REQUIRE_AUTH=1
MCP_HTTP_AUTH_STRICT=1
MCP_HTTP_ENABLED=1
MCP_HTTP_BIND_LOCAL=0
API_ENV=prod
MCP_ENV=prod
API_LISTEN=:8090
NEO4J_URI=neo4j://neo4j:7687

# Keycloak (required when AUTH_ENABLED=1)
# KEYCLOAK_ISSUER=https://keycloak.example/realms/veil
# KEYCLOAK_AUDIENCE=veil-api
# KEYCLOAK_CLIENT_ID=veil-api

# Neo4j: use strong credentials in production (not neo4jpassword)
# NEO4J_AUTH=neo4j/<from-secret>
