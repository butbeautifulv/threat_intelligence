# GAIA agent evaluation (local / CI dispatch only)
# Dataset: https://huggingface.co/datasets/gaia-benchmark/GAIA (gated — accept terms, do not reshare)

# Hugging Face token with access to gaia-benchmark/GAIA
# HF_TOKEN=

# Download cache (gitignored under eval/gaia/data/)
GAIA_DATA_DIR=eval/gaia/data
GAIA_CONFIG=2023_level1
GAIA_SPLIT=validation

# Pilot (offline, committed fixtures — safe for every PR)
# GAIA_TASKS=eval/gaia/fixtures/pilot/metadata.jsonl
# GAIA_SOLVER=scripts/eval/gaia/solvers/stub.sh

# Optional: MCP-backed solver (requires running veil-engage MCP + model API keys)
# GAIA_SOLVER=scripts/eval/gaia/solvers/mcp-engage.sh
# VEIL_ENGAGE_MCP_URL=http://127.0.0.1:8891/mcp
