# GAIA agent evaluation — arXiv:2311.12983 is the primary reference (no HF token required for CI)

# --- Optional: Hugging Face (gated dataset, NOT required for Veil) ---
# Accept terms: https://huggingface.co/datasets/gaia-benchmark/GAIA
# HF_TOKEN=

GAIA_DATA_DIR=eval/gaia/data
GAIA_CONFIG=2023_level1
GAIA_SPLIT=validation

# --- Default CI / local harness (offline) ---
# GAIA_TASKS=eval/gaia/fixtures/pilot/metadata.jsonl
# GAIA_TASKS=eval/gaia/fixtures/paper-examples/metadata.jsonl
# GAIA_SOLVER=scripts/eval/gaia/solvers/stub.sh

# Real agent eval (your MCP client + model keys; not in public CI)
# GAIA_SOLVER=scripts/eval/gaia/solvers/mcp-engage.sh
# VEIL_ENGAGE_MCP_URL=http://127.0.0.1:8891/mcp
