{
  "mcpServers": {
    "veil-graph": {
      "command": "/absolute/path/to/threat_intelligence/scripts/mcp/run-veil-mcp.sh",
      "args": [],
      "env": {
        "NEO4J_URI": "neo4j://localhost:7687",
        "NEO4J_USER": "neo4j",
        "NEO4J_PASS": "neo4jpassword",
        "NEO4J_DB": "neo4j",
        "MCP_ENV": "local"
      },
      "description": "Veil threat-intel graph (read-only)",
      "timeout": 300
    }
  }
}
