{
  "mcpServers": {
    "veil-graph": {
      "command": "/absolute/path/to/threat_intelligence/graph/serve/bin/mcp",
      "args": [],
      "env": {
        "NEO4J_URI": "neo4j://localhost:7687",
        "NEO4J_USER": "neo4j",
        "NEO4J_PASS": "neo4jpassword",
        "NEO4J_DB": "neo4j",
        "AUTH_ENABLED": "1",
        "RBAC_ENABLED": "1",
        "KEYCLOAK_ISSUER": "https://keycloak.example/realms/veil",
        "KEYCLOAK_AUDIENCE": "veil-api",
        "MCP_ACCESS_TOKEN": "REPLACE_WITH_KEYCLOAK_ACCESS_TOKEN"
      }
    }
  }
}
